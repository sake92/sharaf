local const sharafCoreTemplate = (baseTemplate) {
  pomSettings {
    artifactId = "sharaf-core"
    name = "Sharaf Core"
    description = "Core library for Sharaf"
  }
  deps {
    "ba.sake::tupson::0.20.0"
    "com.lihaoyi::geny::1.1.1"
    "com.softwaremill.sttp.client4::core::4.0.5"
  }
}
local const sharafCoreModules =
  new CreateCrossModules {
    root = "sharaf-core"
    template = (sharafCoreTemplate) {
      moduleDeps {
        validsonModules.jvm
        quersonModules.jvm
        formsonModules.jvm
      }
      deps {
        "org.playframework.twirl::twirl-api:2.1.0-M4"
      }
      publish = true
    }
    testTemplate = (sharafCoreTemplate.asTest()) {
      deps { "org.scalameta::munit::1.1.0" }
    }
    nativeTemplate = (sharafCoreTemplate.asNative()) {
      scalaNativeVersion = versions.scalaNativeVersion
      moduleDeps {
        validsonModules.native
        quersonModules.native
        formsonModules.native
      }
      publish = true
    }
    nativeTestTemplate = (nativeTemplate.asTest()) {
      deps { "org.scalameta::munit::1.1.0" }
    }
  }.get

local const sharafHepekComponents = (baseTemplate) {
  id = "sharaf-hepek-components"
  root = "sharaf-hepek-components"
  pomSettings {
    artifactId = "sharaf-hepek-components"
    name = "Sharaf Hepek Components"
    description = "Sharaf integration with hepek-components"
  }
  moduleDeps {
    sharafCoreModules.jvm
  }
  deps { "ba.sake::hepek-components:0.34.0" }
  publish = true
}

local const sharafUndertowModules =
  new CreateScalaModules {
    root = "sharaf-undertow"
    template = (baseTemplate) {
      pomSettings {
        artifactId = "sharaf-undertow"
        name = "Sharaf Undertow"
        description = "Sharaf integration with Undertow"
      }
      moduleDeps {
        sharafCoreModules.jvm
      }
      deps {
        "io.undertow:undertow-core:2.3.18.Final"
        "ba.sake::tupson-config:0.20.0"
      }
      publish = true
    }
    testTemplate = (baseTemplate.asTest()) {
      moduleDeps {
        sharafCoreModules.jvm_test
      }
      deps {
        "org.scalameta::munit::1.1.0"
        "org.webjars:jquery:3.7.1"
      }
    }
  }.get

local const sharafPac4jModules =
  new CreateScalaModules {
    root = "sharaf-pac4j"
    template = (baseTemplate) {
      pomSettings {
        artifactId = "sharaf-pac4j"
        name = "Sharaf Pac4j"
        description = "Sharaf integration with Pac4j security"
      }
      moduleDeps {
        sharafCoreModules.jvm
      }
      deps {
        "org.pac4j:pac4j-core:6.5.3"
      }
      publish = true
    }
    testTemplate = (baseTemplate.asTest()) {
      moduleDeps {
        sharafCoreModules.jvm_test
        sharafJdkHttpserverModules.main
      }
      deps {
        "org.scalameta::munit::1.1.0"
        "org.pac4j:pac4j-http:6.5.3"
        "org.pac4j:pac4j-oidc:6.5.3"
        "no.nav.security:mock-oauth2-server:4.0.0"
        "ba.sake:pac4j-testkit:0.2.0"
      }
    }
  }.get

local const sharafHttp4sModules =
  new CreateCrossModules {
    root = "sharaf-http4s"
    template = (baseTemplate) {
      pomSettings {
        artifactId = "sharaf-http4s"
        name = "Sharaf Http4s"
        description = "Sharaf integration with Http4s"
      }
      moduleDeps { sharafCoreModules.jvm }
      deps { "org.http4s::http4s-server::0.23.34" }
      publish = true
    }
    testTemplate = (baseTemplate.asTest()) {
      deps {
        "org.scalameta::munit::1.1.0"
        "org.http4s::http4s-client::0.23.34"
      }
    }
    nativeTemplate = (template.asNative()) {
      scalaNativeVersion = versions.scalaNativeVersion
      moduleDeps = new { sharafCoreModules.native }
      deps {
        "org.http4s::http4s-server::0.23.34"
        "com.lihaoyi::sourcecode::0.4.2"
        "io.github.cquiroz::scala-java-time::2.6.0"
      }
      publish = true
    }
    nativeTestTemplate = (nativeTemplate.asTest()) {
      multithreading = true
      deps {
        "org.scalameta::munit::1.1.0"
        "org.http4s::http4s-client::0.23.34"
      }
    }
  }.get

