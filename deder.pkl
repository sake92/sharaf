amends "https://sake92.github.io/deder/config/v0.20.0/DederProject.pkl"

import
  "https://sake92.github.io/deder-plugins/config/deder-web-dashboard/early-access/WebDashboardPlugin.pkl"
  as WD

plugins {
  new WD.WebDashboardPlugin {
    version = "0.6.0"
    config = new {
//      enabled = false
    }
  }
}

local const baseTemplate: ScalaModule = new {
  scalaVersion = "3.7.3"
  scalacOptions = new Listing<String> {
    "-Yretain-trees" // needed for default parameters
    "-deprecation"
    "-Wunused:all"
    "-explain"
  }
  pomSettings = new {
    artifactId = "dummy"
    name = "dummy"
    groupId = "ba.sake"
    url = "https://github.com/sake92/sharaf"
    licenses {
      new PomLicense {
        name = "Apache License 2.0"
        url = "https://opensource.org/license/apache-2-0"
      }
    }
    developers {
      new PomDeveloper {
        id = "sake92"
        name = "Sakib Hadžiavdić"
        email = "sakib@sake.ba"
      }
    }
    scm {
      url = "https://github.com/sake92/sharaf"
      connection = "scm:git@github.com:sake92/sharaf.git"
    }
  }
}

local const versions = new {
  scalaJsVersion = "1.19.0"
  scalaNativeVersion = "0.5.11"
}

local const validsonModules =
  new CreateCrossModules {
    root = "validson"
    template = (baseTemplate) {
      pomSettings {
        artifactId = "validson"
        name = "Validson"
        description = "Sharaf validation library"
      }
      deps { "com.lihaoyi::sourcecode::0.4.2" }
      publish = true
    }
    testTemplate = (baseTemplate.asTest()) {
      deps { "org.scalameta::munit::1.1.0" }
    }
    jsTemplate = (template.asJs()) {
      scalaJsVersion = versions.scalaJsVersion
      deps {
        "com.lihaoyi::sourcecode::0.4.2"
        "io.github.cquiroz::scala-java-time::2.6.0"
      }
      publish = true
    }
    jsTestTemplate = (jsTemplate.asTest()) {
      deps { "org.scalameta::munit::1.1.0" }
    }
    nativeTemplate = (template.asNative()) {
      scalaNativeVersion = versions.scalaNativeVersion
      deps {
        "com.lihaoyi::sourcecode::0.4.2"
        "io.github.cquiroz::scala-java-time::2.6.0"
      }
      publish = true
    }
    nativeTestTemplate = (nativeTemplate.asTest()) {
      deps { "org.scalameta::munit::1.1.0" }
    }
  }.get

