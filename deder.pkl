amends "https://sake92.github.io/deder/config/DederProject.pkl"

local const function pomSettings(
  _artifactId: String,
  _name: String,
  _description: String,
): PomSettings = new {
  groupId = "ba.sake"
  artifactId = _artifactId
  version = "0.17.0-SNAPSHOT"
  name = _name
  description = _description
  url = "https://github.com/sake92/sharaf"
  licenses {
    new PomLicense {
      name = "Apache License 2.0"
      url = "https://opensource.org/license/apache-2-0"
    }
  }
  developers {
    new PomDeveloper {
      id = "sake92"
      name = "Sakib Hadžiavdić"
      email = "sakib@sake.ba"
    }
  }
  scm {
    url = "git@github.com:sake92/sharaf.git"
  }
}

local const template: ScalaModule = new {
  scalaVersion = "3.7.3"
  scalacOptions = new Listing<String> {
    "-Yretain-trees" // needed for default parameters
    "-deprecation"
    "-Wunused:all"
    "-explain"
  }
}

local const testTemplate = (template.asTest()) {
  deps {
    "org.scalameta::munit::1.1.0"
  }
  publish = false
}

local const jsTemplate = (template.asJs()) {
  scalaJsVersion = "1.19.0"
  deps {
    "io.github.cquiroz::scala-java-time::2.6.0"
  }
}

local const nativeTemplate = (template.asNative()) {
  scalaNativeVersion = "0.5.9"
  deps {
    "io.github.cquiroz::scala-java-time::2.6.0"
  }
}

local const validsonModules =
  new CreateCrossModules {
    _root = "validson"
    local const _pomSettings = pomSettings("validson", "Validson", "Sharaf validation library")
    _template = (template) {
      pomSettings = _pomSettings
      deps { "com.lihaoyi::sourcecode::0.4.2" }
    }
    _testTemplate = testTemplate
    _jsTemplate = (jsTemplate) {
      pomSettings = _pomSettings
      deps { "com.lihaoyi::sourcecode::0.4.2" }
    }
    _nativeTemplate = (nativeTemplate) {
      pomSettings = _pomSettings
      deps { "com.lihaoyi::sourcecode::0.4.2" }
    }
  }.get

local const quersonModules =
  new CreateCrossModules {
    _root = "querson"
    local const _pomSettings = pomSettings("querson", "Querson", "Sharaf query params library")
    _template = (template) {
      pomSettings = _pomSettings
      deps { "com.lihaoyi::fastparse::3.1.1" }
    }
    _testTemplate = testTemplate
    _jsTemplate = (jsTemplate) {
      pomSettings = _pomSettings
      deps { "com.lihaoyi::fastparse::3.1.1" }
    }
    _nativeTemplate = (nativeTemplate) {
      pomSettings = _pomSettings
      deps { "com.lihaoyi::fastparse::3.1.1" }
    }
  }.get

local const formsonModules =
  new CreateCrossModules {
    _root = "formson"
    local const _pomSettings = pomSettings("formson", "Formson", "Sharaf form binding library")
    _template = (template) {
      pomSettings = _pomSettings
      deps { "com.lihaoyi::fastparse::3.1.1" }
    }
    _testTemplate = testTemplate
    _jsTemplate = (jsTemplate) {
      pomSettings = _pomSettings
      deps { "com.lihaoyi::fastparse::3.1.1" }
    }
    _nativeTemplate = (nativeTemplate) {
      pomSettings = _pomSettings
      deps { "com.lihaoyi::fastparse::3.1.1" }
    }
  }.get

local const sharafCoreTemplate = (template) {
  deps {
    "ba.sake::tupson::0.18.0"
    "com.lihaoyi::geny::1.1.1"
    "com.softwaremill.sttp.client4::core::4.0.5"
  }
}
local const sharafCoreModules =
  new CreateCrossModules {
    _root = "sharaf-core"
    _template = (sharafCoreTemplate) {
      pomSettings = pomSettings("sharaf-core", "Sharaf Core", "Core library for Sharaf")
      moduleDeps {
        validsonModules.jvm
        quersonModules.jvm
        formsonModules.jvm
      }
      deps {
        "org.playframework.twirl::twirl-api:2.1.0-M4"
      }
    }
    _testTemplate = testTemplate
    _jsTemplate = jsTemplate
    _nativeTemplate = (nativeTemplate) {
      pomSettings = pomSettings("sharaf-core", "Sharaf Core", "Core library for Sharaf")
      deps = sharafCoreTemplate.deps
      moduleDeps {
        validsonModules.native
        quersonModules.native
        formsonModules.native
      }
    }
  }.get

local const sharafUndertowModules =
  new CreateScalaModules {
    _root = "sharaf-undertow"
    _template = (template) {
      pomSettings =
        pomSettings(
          "sharaf-undertow",
          "Sharaf Undertow",
          "Sharaf integration with Undertow",
        )
      moduleDeps {
        sharafCoreModules.jvm
      }
      deps {
        "io.undertow:undertow-core:2.3.18.Final"
        "ba.sake::tupson-config:0.18.0"
      }
    }
    _testTemplate = (testTemplate) {
      moduleDeps {
        sharafCoreModules.jvm_test
      }
      deps {
        "org.webjars:jquery:3.7.1"
      }
    }
  }.get

local const sharafHttp4sModules =
  new CreateScalaModules {
    _root = "sharaf-http4s"
    _template = (template) {
      pomSettings = pomSettings("sharaf-http4s", "Sharaf Http4s", "Sharaf integration with Http4s")
      moduleDeps {
        sharafCoreModules.jvm
      }
      deps {
        "org.http4s::http4s-server::0.23.32"
      }
    }
    _testTemplate = (testTemplate) {
      deps {
        "org.http4s::http4s-client::0.23.32"
      }
    }
  }.get

local const sharafHelidonModules =
  new CreateScalaModules {
    _root = "sharaf-helidon"
    _template = (template) {
      pomSettings =
        pomSettings("sharaf-helidon", "Sharaf Helidon", "Sharaf integration with Helidon")
      moduleDeps {
        sharafCoreModules.jvm
      }
      deps {
        "io.helidon.webserver:helidon-webserver:4.2.2"
        "io.helidon.config:helidon-config-yaml:4.2.2"
      }
    }
    _testTemplate = (testTemplate) {
      moduleDeps {
        sharafCoreModules.jvm_test
      }
    }
  }.get

local const sharafJdkHttpserverModules =
  new CreateScalaModules {
    _root = "sharaf-jdk-httpserver"
    _template = (template) {
      pomSettings =
        pomSettings(
          "sharaf-jdk-httpserver",
          "Sharaf JDK HttpServer",
          "Sharaf integration with JDK HttpServer",
        )
      moduleDeps {
        sharafCoreModules.jvm
      }
    }
    _testTemplate = (testTemplate) {
      moduleDeps {
        sharafCoreModules.jvm_test
      }
    }
  }.get

local const sharafSnunit = (nativeTemplate) {
  id = "sharaf-snunit"
  root = "sharaf-snunit"
  pomSettings = pomSettings("sharaf-snunit", "Sharaf Snunit", "Sharaf integration with Snunit")
  moduleDeps {
    sharafCoreModules.native
  }
  deps {
    "com.github.lolgab::snunit::0.10.3"
  }
}

modules {
  ...validsonModules.all
  ...quersonModules.all
  ...formsonModules.all
  sharafCoreModules.jvm
  sharafCoreModules.jvm_test
  sharafCoreModules.native
  ...sharafUndertowModules.all
  ...sharafHttp4sModules.all
  ...sharafHelidonModules.all
  ...sharafJdkHttpserverModules.all
  sharafSnunit
}
