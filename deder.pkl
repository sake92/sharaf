local const sharafCoreTemplate = (baseTemplate) {
  pomSettings = pomSettings("sharaf-core", "Sharaf Core", "Core library for Sharaf")
  deps {
    "ba.sake::tupson::0.18.0"
    "com.lihaoyi::geny::1.1.1"
    "com.softwaremill.sttp.client4::core::4.0.5"
  }
}
local const sharafCoreModules =
  new CreateCrossModules {
    root = "sharaf-core"
    template = (sharafCoreTemplate) {
      moduleDeps {
        validsonModules.jvm
        quersonModules.jvm
        formsonModules.jvm
      }
      deps {
        "org.playframework.twirl::twirl-api:2.1.0-M4"
      }
    }
    testTemplate = (sharafCoreTemplate.asTest()) {
      deps { "org.scalameta::munit::1.1.0" }
    }
    nativeTemplate = (sharafCoreTemplate.asNative()) {
      scalaNativeVersion = versions.scalaNativeVersion
      moduleDeps {
        validsonModules.native
        quersonModules.native
        formsonModules.native
      }
    }
    nativeTestTemplate = (nativeTemplate.asTest()) {
      deps { "org.scalameta::munit::1.1.0" }
    }
  }.get

local const sharafHepekComponents = (baseTemplate) {
  id = "sharaf-hepek-components"
  root = "sharaf-hepek-components"
  pomSettings =
    pomSettings(root, "Sharaf Hepek Components", "Sharaf integration with hepek-components")
  moduleDeps {
    sharafCoreModules.jvm
  }
  deps { "ba.sake::hepek-components:0.34.0" }
}

local const sharafUndertowModules =
  new CreateScalaModules {
    root = "sharaf-undertow"
    template = (baseTemplate) {
      pomSettings =
        pomSettings("sharaf-undertow", "Sharaf Undertow", "Sharaf integration with Undertow")
      moduleDeps {
        sharafCoreModules.jvm
      }
      deps {
        "io.undertow:undertow-core:2.3.18.Final"
        "ba.sake::tupson-config:0.18.0"
      }
    }
    testTemplate = (baseTemplate.asTest()) {
      moduleDeps {
        sharafCoreModules.jvm_test
      }
      deps {
        "org.scalameta::munit::1.1.0"
        "org.webjars:jquery:3.7.1"
      }
    }
  }.get

local const sharafHttp4sModules =
  new CreateCrossModules {
    root = "sharaf-http4s"
    local const _pomSettings =
      pomSettings("sharaf-http4s", "Sharaf Http4s", "Sharaf integration with Http4s")
    template = (baseTemplate) {
      pomSettings = _pomSettings
      moduleDeps { sharafCoreModules.jvm }
      deps { "org.http4s::http4s-server::0.23.34" }
    }
    testTemplate = (baseTemplate.asTest()) {
      deps {
        "org.scalameta::munit::1.1.0"
        "org.http4s::http4s-client::0.23.34"
      }
    }
    nativeTemplate = (baseTemplate.asNative()) {
      scalaNativeVersion = versions.scalaNativeVersion
      pomSettings = _pomSettings
      moduleDeps { sharafCoreModules.native }
      deps {
        "org.http4s::http4s-server::0.23.34"
        "com.lihaoyi::sourcecode::0.4.2"
        "io.github.cquiroz::scala-java-time::2.6.0"
      }
    }
    nativeTestTemplate = (nativeTemplate.asTest()) {
      multithreading = true
      deps {
        "org.scalameta::munit::1.1.0"
        "org.http4s::http4s-client::0.23.34"
      }
    }
  }.get

local const sharafHelidonModules =
  new CreateScalaModules {
    root = "sharaf-helidon"
    template = (baseTemplate) {
      pomSettings =
        pomSettings("sharaf-helidon", "Sharaf Helidon", "Sharaf integration with Helidon")
      moduleDeps {
        sharafCoreModules.jvm
      }
      deps {
        "io.helidon.webserver:helidon-webserver:4.2.2"
        "io.helidon.config:helidon-config-yaml:4.2.2"
      }
    }
    testTemplate = (baseTemplate.asTest()) {
      moduleDeps {
        sharafCoreModules.jvm_test
      }
    }
  }.get

local const sharafJdkHttpserverModules =
  new CreateScalaModules {
    root = "sharaf-jdk-httpserver"
    template = (baseTemplate) {
      pomSettings =
        pomSettings(
          "sharaf-jdk-httpserver",
          "Sharaf JDK HttpServer",
          "Sharaf integration with JDK HttpServer",
        )
      moduleDeps {
        sharafCoreModules.jvm
      }
    }
    testTemplate = (baseTemplate.asTest()) {
      moduleDeps {
        sharafCoreModules.jvm_test
      }
    }
  }.get

local const sharafSnunit = (baseTemplate.asNative()) {
  id = "sharaf-snunit"
  root = "sharaf-snunit"
  scalaNativeVersion = versions.scalaNativeVersion
  pomSettings = pomSettings("sharaf-snunit", "Sharaf Snunit", "Sharaf integration with Snunit")
  moduleDeps {
    sharafCoreModules.native
  }
  deps { "com.github.lolgab::snunit::0.10.3" }
}

// examples
local const baseExampleTemplate = (baseTemplate) {
  publish = false
  deps { "ch.qos.logback:logback-classic:1.4.6" }
}

local const apiExampleModules =
  new CreateScalaModules {
    root = "examples/api"
    template = (baseExampleTemplate) {
      moduleDeps { sharafUndertowModules.main }
    }
    testTemplate = (baseExampleTemplate.asTest()) {
      deps { "org.scalameta::munit::1.1.0" }
    }
  }.get

local const fullstackExampleModules =
  new CreateScalaModules {
    root = "examples/fullstack"
    template = (baseExampleTemplate) {
      moduleDeps { sharafUndertowModules.main }
    }
    testTemplate = (baseExampleTemplate.asTest()) {
      deps { "org.scalameta::munit::1.1.0" }
    }
  }.get

