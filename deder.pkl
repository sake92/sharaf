local const sharafSnunit = (baseTemplate.asNative()) {
  id = "sharaf-snunit"
  root = "sharaf-snunit"
  scalaNativeVersion = versions.scalaNativeVersion
  pomSettings {
    artifactId = "sharaf-snunit"
    name = "Sharaf Snunit"
    description = "Sharaf integration with Snunit"
  }
  moduleDeps {
    sharafCoreModules.native
  }
  deps { "com.github.lolgab::snunit::0.10.3" }
  publish = true
}

// examples
local const baseExampleTemplate = (baseTemplate) {
  deps { "ch.qos.logback:logback-classic:1.4.6" }
}

local const apiExampleModules =
  new CreateScalaModules {
    root = "examples/api"
    template = (baseExampleTemplate) {
      moduleDeps { sharafUndertowModules.main }
    }
    testTemplate = (baseExampleTemplate.asTest()) {
      deps { "org.scalameta::munit::1.1.0" }
    }
  }.get

