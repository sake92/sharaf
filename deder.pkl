//amends "https://sake92.github.io/deder/config/v0.3.1/DederProject.pkl"

amends "https://sake92.github.io/deder/config/early-access/DederProject.pkl"

local const function pomSettings(
  _artifactId: String,
  _name: String,
  _description: String,
): PomSettings = new {
  groupId = "ba.sake"
  artifactId = _artifactId
  name = _name
  description = _description
  url = "https://github.com/sake92/sharaf"
  licenses {
    new PomLicense {
      name = "Apache License 2.0"
      url = "https://opensource.org/license/apache-2-0"
    }
  }
  developers {
    new PomDeveloper {
      id = "sake92"
      name = "Sakib Hadžiavdić"
      email = "sakib@sake.ba"
    }
  }
  scm {
    url = "git@github.com:sake92/sharaf.git"
  }
}

local const baseTemplate: ScalaModule = new {
  scalaVersion = "3.7.3"
  scalacOptions = new Listing<String> {
    "-Yretain-trees" // needed for default parameters
    "-deprecation"
    "-Wunused:all"
    "-explain"
  }
}

local const versions = new {
  scalaJsVersion = "1.19.0"
  scalaNativeVersion = "0.5.9"
}

local const validsonModules =
  new CreateCrossModules {
    root = "validson"
    local const _pomSettings = pomSettings("validson", "Validson", "Sharaf validation library")
    template = (baseTemplate) {
      pomSettings = _pomSettings
      deps { "com.lihaoyi::sourcecode::0.4.2" }
    }
    testTemplate = (baseTemplate.asTest()) {
      deps { "org.scalameta::munit::1.1.0" }
    }
    jsTemplate = (baseTemplate.asJs()) {
      scalaJsVersion = versions.scalaJsVersion
      pomSettings = _pomSettings
      deps {
        "com.lihaoyi::sourcecode::0.4.2"
        "io.github.cquiroz::scala-java-time::2.6.0"
      }
    }
    jsTestTemplate = (jsTemplate.asTest()) {
      deps { "org.scalameta::munit::1.1.0" }
    }
    nativeTemplate = (baseTemplate.asNative()) {
      scalaNativeVersion = versions.scalaNativeVersion
      pomSettings = _pomSettings
      deps {
        "com.lihaoyi::sourcecode::0.4.2"
        "io.github.cquiroz::scala-java-time::2.6.0"
      }
    }
    nativeTestTemplate = (nativeTemplate.asTest()) {
      deps { "org.scalameta::munit::1.1.0" }
    }
  }.get

local const quersonModules =
  new CreateCrossModules {
    root = "querson"
    local const _pomSettings = pomSettings("querson", "Querson", "Sharaf query params library")
    template = (baseTemplate) {
      pomSettings = _pomSettings
      deps { "com.lihaoyi::fastparse::3.1.1" }
    }
    testTemplate = (baseTemplate.asTest()) {
      deps { "org.scalameta::munit::1.1.0" }
    }
    jsTemplate = (baseTemplate.asJs()) {
      scalaJsVersion = versions.scalaJsVersion
      pomSettings = _pomSettings
      deps {
        "com.lihaoyi::fastparse::3.1.1"
        "io.github.cquiroz::scala-java-time::2.6.0"
      }
    }
    jsTestTemplate = (jsTemplate.asTest()) {
      deps { "org.scalameta::munit::1.1.0" }
    }
    nativeTemplate = (baseTemplate.asNative()) {
      scalaNativeVersion = versions.scalaNativeVersion
      pomSettings = _pomSettings
      deps {
        "com.lihaoyi::fastparse::3.1.1"
        "io.github.cquiroz::scala-java-time::2.6.0"
      }
    }
    nativeTestTemplate = (nativeTemplate.asTest()) {
      deps { "org.scalameta::munit::1.1.0" }
    }
  }.get

local const formsonModules =
  new CreateCrossModules {
    root = "formson"
    local const _pomSettings = pomSettings("formson", "Formson", "Sharaf form binding library")
    template = (baseTemplate) {
      pomSettings = _pomSettings
      deps { "com.lihaoyi::fastparse::3.1.1" }
    }
    testTemplate = (baseTemplate.asTest()) {
      deps { "org.scalameta::munit::1.1.0" }
    }
    jsTemplate = (baseTemplate.asJs()) {
      scalaJsVersion = versions.scalaJsVersion
      pomSettings = _pomSettings
      deps {
        "com.lihaoyi::fastparse::3.1.1"
        "io.github.cquiroz::scala-java-time::2.6.0"
      }
    }
    jsTestTemplate = (jsTemplate.asTest()) {
      deps { "org.scalameta::munit::1.1.0" }
    }
    nativeTemplate = (baseTemplate.asNative()) {
      scalaNativeVersion = versions.scalaNativeVersion
      pomSettings = _pomSettings
      deps {
        "com.lihaoyi::fastparse::3.1.1"
        "io.github.cquiroz::scala-java-time::2.6.0"
      }
    }
    nativeTestTemplate = (nativeTemplate.asTest()) {
      deps { "org.scalameta::munit::1.1.0" }
