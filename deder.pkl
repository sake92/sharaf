modules {
  ...validsonModules.all
  ...quersonModules.all
  formsonModules.jvm
  formsonModules.jvm_test
  // java.nio.Path not supported in Scala.js
  formsonModules.native
  formsonModules.native_test
  sharafHepekComponents
  sharafCoreModules.jvm
  sharafCoreModules.jvm_test
  sharafCoreModules.native
  sharafCoreModules.native_test
  ...sharafUndertowModules.all
  sharafHttp4sModules.jvm
  sharafHttp4sModules.jvm_test
  sharafHttp4sModules.native
  sharafHttp4sModules.native_test
  ...sharafHelidonModules.all
  ...sharafJdkHttpserverModules.all
  ...sharafPac4jModules.all
  sharafSnunit
  ...apiExampleModules.all
  ...fullstackExampleModules.all
  ...userPassFormExampleModules.all
  ...jwtExampleModules.all
  ...oauth2ExampleModules.all
  ...jdkHttpserverExampleModules.all
  ...snunitExampleModules.all
